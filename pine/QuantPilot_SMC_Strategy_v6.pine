//@version=6
// ────────────────────────────────────────────────────────────
// QuantPilot AI - Multi-TF SMC Confluence Strategy v6
//
// 配合 QuantPilot AI 后端的 TradingView 策略版
// 可在 TradingView 内回测，也可通过 webhook 发送到后端实盘
// ────────────────────────────────────────────────────────────
strategy("QuantPilot SMC Strategy", "QP-SMC-Strategy v6",
     overlay = true,
     pyramiding = 0,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 100,
     initial_capital = 10000,
     commission_type = strategy.commission.percent,
     commission_value = 0.1,
     use_bar_magnifier = true)

// ═══════════════════════════════════════════════════════════
// 输入参数
// ═══════════════════════════════════════════════════════════

// ── Webhook ──
WEBHOOK_SECRET = input.string("YOUR_SECRET_HERE", "Webhook Secret", group = "Webhook")
EXCHANGE_NAME  = input.string("BINANCE", "交易所", options = ["BINANCE", "OKX", "BYBIT", "BITGET", "GATE", "COINBASE"], group = "Webhook")
ENABLE_WEBHOOK = input.bool(false, "启用 Webhook 发送", group = "Webhook")

// ── 时间框架 ──
HTF_TIMEFRAME = input.timeframe("240", "HTF", options = ["60", "240", "D", "W"], group = "时间框架")
ETF_TIMEFRAME = input.timeframe("15", "ETF", options = ["5", "15", "30", "60"], group = "时间框架")

// ── EMA ──
EMA_FAST   = input.int(20, "EMA 快线", 1, 200, group = "趋势")
EMA_MEDIUM = input.int(50, "EMA 中线", 1, 200, group = "趋势")
EMA_SLOW   = input.int(200, "EMA 慢线", 1, 500, group = "趋势")

// ── RSI ──
RSI_LENGTH = input.int(14, "RSI 周期", group = "动量")
RSI_OS     = input.int(30, "RSI 超卖", 0, 50, group = "动量")
RSI_OB     = input.int(70, "RSI 超买", 50, 100, group = "动量")

// ── ATR (风控) ──
ATR_LENGTH  = input.int(14, "ATR 周期", group = "风控")
ATR_SL_MULT = input.float(1.5, "止损 ATR 倍数", 0.5, 5.0, 0.1, group = "风控")
ATR_TP1     = input.float(2.0, "TP1 ATR", 0.5, 10.0, 0.1, group = "风控")
ATR_TP2     = input.float(3.5, "TP2 ATR", 0.5, 15.0, 0.1, group = "风控")
ATR_TP3     = input.float(5.0, "TP3 ATR", 0.5, 20.0, 0.1, group = "风控")
POS_SIZE_PCT = input.float(100, "仓位 %", 1, 100, group = "风控")

// ── FVG ──
FVG_MIN_PCT  = input.float(0.1, "FVG 最小 %", 0.01, 2.0, 0.01, group = "SMC")
FVG_MAX_BARS = input.int(10, "FVG 最大 K 线", 1, 50, group = "SMC")

// ── 成交量 ──
VOL_MA_LEN   = input.int(20, "量均线周期", group = "成交量")
VOL_SPIKE_X  = input.float(1.5, "量突增倍数", 1.0, 5.0, 0.1, group = "成交量")

// ── 策略 ──
FILTER_MODE     = input.string("normal", "筛选模式", options = ["conservative", "normal", "aggressive"], group = "策略")
SIGNAL_COOLDOWN = input.int(5, "冷却 K 线", 1, 30, group = "策略")
ENABLE_LONG     = input.bool(true, "允许做多", group = "策略")
ENABLE_SHORT    = input.bool(true, "允许做空", group = "策略")

// ═══════════════════════════════════════════════════════════
// 数据计算
// ═══════════════════════════════════════════════════════════

// 多时间框架
htf_close = request.security(syminfo.tickerid, HTF_TIMEFRAME, close, lookahead = barmerge.lookahead_off)
htf_ema20 = request.security(syminfo.tickerid, HTF_TIMEFRAME, ta.ema(close, EMA_FAST), lookahead = barmerge.lookahead_off)
htf_ema50 = request.security(syminfo.tickerid, HTF_TIMEFRAME, ta.ema(close, EMA_MEDIUM), lookahead = barmerge.lookahead_off)

// EMA
ema20  = ta.ema(close, EMA_FAST)
ema50  = ta.ema(close, EMA_MEDIUM)
ema200 = ta.ema(close, EMA_SLOW)

// RSI / ATR / Volume
rsi   = ta.rsi(close, RSI_LENGTH)
atr   = ta.atr(ATR_LENGTH)
vol_ma = ta.sma(volume, VOL_MA_LEN)
vol_ok = volume > vol_ma * VOL_SPIKE_X

// ═══════════════════════════════════════════════════════════
// 市场结构
// ═══════════════════════════════════════════════════════════

// HTF 趋势
htf_bull  = htf_ema20 > htf_ema50 and htf_close > htf_ema20
htf_bear  = htf_ema20 < htf_ema50 and htf_close < htf_ema20
htf_range = not htf_bull and not htf_bear

// EMA 排列
ema_bull_align = ema20 > ema50 and ema50 > ema200
ema_bear_align = ema20 < ema50 and ema50 < ema200

// ═══════════════════════════════════════════════════════════
// FVG 检测
// ═══════════════════════════════════════════════════════════

fvg_size_pct(top, bot) => math.abs(top - bot) / bot * 100

var float fvg_bull_top = na
var float fvg_bull_bot = na
var int   fvg_bull_idx = 0
var float fvg_bear_top = na
var float fvg_bear_bot = na
var int   fvg_bear_idx = 0

if low > high[2]  // Bullish FVG
    sz = fvg_size_pct(low, high[2])
    if sz >= FVG_MIN_PCT
        fvg_bull_top := low
        fvg_bull_bot := high[2]
        fvg_bull_idx := bar_index

if high < low[2]  // Bearish FVG
    sz = fvg_size_pct(low[2], high)
    if sz >= FVG_MIN_PCT
        fvg_bear_top := low[2]
        fvg_bear_bot := high
        fvg_bear_idx := bar_index

fvg_bull_active = bar_index - fvg_bull_idx <= FVG_MAX_BARS
fvg_bear_active = bar_index - fvg_bear_idx <= FVG_MAX_BARS

// FVG 回填触发
fvg_bull_fill = fvg_bull_active and low <= fvg_bull_top and close > fvg_bull_top
fvg_bear_fill = fvg_bear_active and high >= fvg_bear_bot and close < fvg_bear_bot

// ═══════════════════════════════════════════════════════════
// 信号生成
// ═══════════════════════════════════════════════════════════

consv = FILTER_MODE == "conservative"
aggro = FILTER_MODE == "aggressive"

// 趋势条件
bull_trend_ok = consv ? (htf_bull and ema_bull_align) : (not htf_bear and ema20 > ema50)
bear_trend_ok = consv ? (htf_bear and ema_bear_align) : (not htf_bull and ema20 < ema50)

// RSI 条件
rsi_long_ok  = not aggro ? (rsi > RSI_OS and rsi < 65) : (rsi > 25 and rsi < 80)
rsi_short_ok = not aggro ? (rsi < RSI_OB and rsi > 35) : (rsi < 80 and rsi > 20)

// 入场区域
long_entry =
     (fvg_bull_fill and close > fvg_bull_top) or
     (ta.crossover(ema20, ema50) and rsi_long_ok)

short_entry =
     (fvg_bear_fill and close < fvg_bear_bot) or
     (ta.crossunder(ema20, ema50) and rsi_short_ok)

long_signal  = long_entry and bull_trend_ok and rsi_long_ok and (aggro or vol_ok) and not htf_range
short_signal = short_entry and bear_trend_ok and rsi_short_ok and (aggro or vol_ok) and not htf_range

// 平仓
close_long  = ta.crossunder(ema20, ema50) or rsi > 75 or (htf_bear and close < ema20)
close_short = ta.crossover(ema20, ema50) or rsi < 25 or (htf_bull and close > ema20)

// ═══════════════════════════════════════════════════════════
// 冷却机制
// ═══════════════════════════════════════════════════════════

var int last_long  = -999
var int last_short = -999

long_cool_ok  = bar_index - last_long  >= SIGNAL_COOLDOWN
short_cool_ok = bar_index - last_short >= SIGNAL_COOLDOWN

// ═══════════════════════════════════════════════════════════
// 入场执行
// ═══════════════════════════════════════════════════════════

long_final  = ENABLE_LONG and long_signal and long_cool_ok
short_final = ENABLE_SHORT and short_signal and short_cool_ok

if long_final
    last_long := bar_index
    sl  = close - atr * ATR_SL_MULT
    tp1 = close + atr * ATR_TP1
    tp2 = close + atr * ATR_TP2
    tp3 = close + atr * ATR_TP3
    qty = POS_SIZE_PCT

    strategy.entry("LONG", strategy.long, qty = qty)
    strategy.exit("LONG.TP", "LONG",
         stop = sl, limit = tp1,
         comment = "SL/TP1")
    // 注意: Pine 不支持多 TP 在一个 exit 里，使用多个 exit 需分别管理

    if ENABLE_WEBHOOK
        alert('{"secret":"' + WEBHOOK_SECRET + '",' +
            '"ticker":"' + syminfo.ticker + '",' +
            '"exchange":"' + EXCHANGE_NAME + '",' +
            '"direction":"long",' +
            '"price":' + str.tostring(close) + ',' +
            '"timeframe":"' + str.tostring(timeframe.multiplier) + '",' +
            '"strategy":"QP-SMCv6","message":"sig=long|entry=' + str.tostring(close, "#.##") +
            '|sl=' + str.tostring(sl, "#.##") +
            '|tp1=' + str.tostring(tp1, "#.##") +
            '|tp2=' + str.tostring(tp2, "#.##") +
            '|tp3=' + str.tostring(tp3, "#.##") +
            '|atr=' + str.tostring(atr, "#.##") +
            '|filter=' + FILTER_MODE + '"}',
            alert.freq_once_per_bar_close)

if short_final
    last_short := bar_index
    sl  = close + atr * ATR_SL_MULT
    tp1 = close - atr * ATR_TP1
    tp2 = close - atr * ATR_TP2
    tp3 = close - atr * ATR_TP3
    qty = POS_SIZE_PCT

    strategy.entry("SHORT", strategy.short, qty = qty)
    strategy.exit("SHORT.TP", "SHORT",
         stop = sl, limit = tp1,
         comment = "SL/TP1")

    if ENABLE_WEBHOOK
        alert('{"secret":"' + WEBHOOK_SECRET + '",' +
            '"ticker":"' + syminfo.ticker + '",' +
            '"exchange":"' + EXCHANGE_NAME + '",' +
            '"direction":"short",' +
            '"price":' + str.tostring(close) + ',' +
            '"timeframe":"' + str.tostring(timeframe.multiplier) + '",' +
            '"strategy":"QP-SMCv6","message":"sig=short|entry=' + str.tostring(close, "#.##") +
            '|sl=' + str.tostring(sl, "#.##") +
            '|tp1=' + str.tostring(tp1, "#.##") +
            '|tp2=' + str.tostring(tp2, "#.##") +
            '|tp3=' + str.tostring(tp3, "#.##") +
            '|atr=' + str.tostring(atr, "#.##") +
            '|filter=' + FILTER_MODE + '"}',
            alert.freq_once_per_bar_close)

// 平仓
if close_long
    strategy.close("LONG", comment = "CLOSE_LONG")
    if ENABLE_WEBHOOK
        alert('{"secret":"' + WEBHOOK_SECRET + '",' +
            '"ticker":"' + syminfo.ticker + '",' +
            '"exchange":"' + EXCHANGE_NAME + '",' +
            '"direction":"close_long","price":' + str.tostring(close) + ',' +
            '"timeframe":"' + str.tostring(timeframe.multiplier) + '",' +
            '"strategy":"QP-SMCv6","message":"sig=close_long|price=' + str.tostring(close, "#.##") + '"}',
            alert.freq_once_per_bar_close)

if close_short
    strategy.close("SHORT", comment = "CLOSE_SHORT")
    if ENABLE_WEBHOOK
        alert('{"secret":"' + WEBHOOK_SECRET + '",' +
            '"ticker":"' + syminfo.ticker + '",' +
            '"exchange":"' + EXCHANGE_NAME + '",' +
            '"direction":"close_short","price":' + str.tostring(close) + ',' +
            '"timeframe":"' + str.tostring(timeframe.multiplier) + '",' +
            '"strategy":"QP-SMCv6","message":"sig=close_short|price=' + str.tostring(close, "#.##") + '"}',
            alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════
// 可视化
// ═══════════════════════════════════════════════════════════

plot(ema20, "EMA" + str.tostring(EMA_FAST), color.blue, 2)
plot(ema50, "EMA" + str.tostring(EMA_MEDIUM), color.orange, 2)
plot(ema200, "EMA" + str.tostring(EMA_SLOW), color.gray, 1)

bgcolor(fvg_bull_active ? color.new(color.green, 88) : na, title = "FVG Bull")
bgcolor(fvg_bear_active ? color.new(color.red, 88) : na, title = "FVG Bear")

plotshape(long_final,  "LONG",  shape.triangleup,   location.belowbar, color.green, size = size.small, text = "L")
plotshape(short_final, "SHORT", shape.triangledown, location.abovebar, color.red,   size = size.small, text = "S")
plotshape(close_long,  "CLOSE_L", shape.xcross, location.abovebar, color.orange, size = size.tiny)
plotshape(close_short, "CLOSE_S", shape.xcross, location.belowbar, color.orange, size = size.tiny)
