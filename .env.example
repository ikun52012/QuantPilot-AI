# =========================
# AI Provider (choose one)
# =========================
AI_PROVIDER=deepseek
# Options: openai, anthropic, deepseek, custom

OPENAI_API_KEY=***
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=***
ANTHROPIC_MODEL=claude-sonnet-4-20250514

DEEPSEEK_API_KEY=***
DEEPSEEK_MODEL=deepseek-chat

# =========================
# Custom AI Provider Configuration
# =========================
# Enable custom AI provider
CUSTOM_AI_PROVIDER_ENABLED=false
# Name for the custom provider (used as AI_PROVIDER value)
CUSTOM_AI_PROVIDER_NAME=custom
# API key for custom provider
CUSTOM_AI_API_KEY=***
# Model name for custom provider
CUSTOM_AI_MODEL=gpt-3.5-turbo
# API endpoint URL for custom provider (must be OpenAI-compatible)
CUSTOM_AI_API_URL=https://api.example.com/v1/chat/completions

# =========================
# Exchange (Binance, OKX, Bybit, Bitget, Gate, Coinbase)
# =========================
EXCHANGE=binance
EXCHANGE_API_KEY=***
EXCHANGE_API_SECRET=***
EXCHANGE_PASSWORD=***
# Required for OKX and Bitget (passphrase)

# Set to true for real trading, false for paper trading
LIVE_TRADING=false

# =========================
# Telegram Notifications
# =========================
TELEGRAM_BOT_TOKEN=***
TELEGRAM_CHAT_ID=xxxx

# =========================
# Server
# =========================
# Leave empty to let the app generate and persist one in data/server.db, or set your own strong value.
WEBHOOK_SECRET=
# Optional strict HMAC body signature. If set, TradingView/proxy sender must include
# X-TVSS-Signature: sha256=<hex_hmac_sha256_of_raw_body>
WEBHOOK_HMAC_SECRET=
JWT_SECRET=replace-with-a-long-random-string
APP_ENCRYPTION_KEY=
DEFAULT_ADMIN_PASSWORD=123456
HOST=0.0.0.0
PORT=8000
# Leave empty to auto-detect from the current request/proxy headers.
# Set only if auto-detection is wrong, for example: https://cs.hyzcjs.com
PUBLIC_BASE_URL=
COOKIE_SECURE=true
POSITION_MONITOR_INTERVAL_SECS=60
AI_CONNECT_TIMEOUT_SECS=10
AI_READ_TIMEOUT_SECS=90
AI_WRITE_TIMEOUT_SECS=30
AI_POOL_TIMEOUT_SECS=10
JSON_LOGS=false

# =========================
# Optional On-chain Payment Verification
# =========================
# EVM networks use explorer proxy APIs to read transaction receipts.
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
ARBISCAN_API_KEY=
ETHERSCAN_API_URL=https://api.etherscan.io/api
BSCSCAN_API_URL=https://api.bscscan.com/api
ARBISCAN_API_URL=https://api.arbiscan.io/api
TRONGRID_API_KEY=
TRONGRID_API_URL=https://api.trongrid.io
APTOS_API_URL=https://fullnode.mainnet.aptoslabs.com/v1
UVICORN_RELOAD=false

# =========================
# Risk Management
# =========================
ACCOUNT_EQUITY_USDT=10000
MAX_POSITION_PCT=10.0
MAX_DAILY_TRADES=10
MAX_DAILY_LOSS_PCT=5.0
# Comma-separated rule keys to bypass, e.g. spread,market_hours
PREFILTER_DISABLED_CHECKS=
# Options: ai, custom
EXIT_MANAGEMENT_MODE=ai
# Options: conservative, balanced, aggressive
AI_RISK_PROFILE=balanced
CUSTOM_STOP_LOSS_PCT=1.5
AI_EXIT_SYSTEM_PROMPT=Generate a protective stop loss and up to four take-profit levels. Keep risk/reward at least 1:1.5 unless market conditions are poor.

# =========================
# USDT Payment Addresses
# =========================
# These can also be edited in Admin -> USDT Payment Addresses.
PAYMENT_ADDRESS_TRC20=
PAYMENT_ADDRESS_ERC20=
PAYMENT_ADDRESS_BEP20=
PAYMENT_ADDRESS_ARBITRUM=
PAYMENT_ADDRESS_APT=
PAYMENT_ADDRESS_SOL=
