# =========================
# AI Provider (choose one)
# =========================
AI_PROVIDER=deepseek
# Options: openai, anthropic, deepseek

OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_MODEL=deepseek-chat

# =========================
# Exchange (Binance, OKX, Bybit, Bitget, Gate, Coinbase)
# =========================
EXCHANGE=binance
EXCHANGE_API_KEY=xxxx
EXCHANGE_API_SECRET=xxxx
EXCHANGE_PASSWORD=       # Required for OKX and Bitget (passphrase)

# Set to true for real trading, false for paper trading
LIVE_TRADING=false

# =========================
# Telegram Notifications
# =========================
TELEGRAM_BOT_TOKEN=xxxx
TELEGRAM_CHAT_ID=xxxx

# =========================
# Server
# =========================
WEBHOOK_SECRET=your-random-secret-string-here
HOST=0.0.0.0
PORT=8000

# =========================
# Risk Management
# =========================
MAX_POSITION_PCT=10.0
MAX_DAILY_TRADES=10
MAX_DAILY_LOSS_PCT=5.0
