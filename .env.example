# ─────────────────────────────────────────────
# QuantPilot AI Configuration
# ─────────────────────────────────────────────

# Application
APP_NAME=QuantPilot AI
DEBUG=false
JSON_LOGS=false

# ─────────────────────────────────────────────
# Security (REQUIRED for production)
# ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters
WEBHOOK_SECRET=change-this-to-your-webhook-secret
WEBHOOK_HMAC_SECRET=
COOKIE_SECURE=auto

# Encryption key for sensitive data at rest
APP_ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# Default Admin Account
# ─────────────────────────────────────────────
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@localhost
DEFAULT_ADMIN_PASSWORD=123456

# ─────────────────────────────────────────────
# AI Provider Configuration
# ─────────────────────────────────────────────
AI_PROVIDER=deepseek
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=1000
AI_CUSTOM_PROMPT=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=QuantPilot AI

# Custom AI Provider
CUSTOM_AI_PROVIDER_ENABLED=false
CUSTOM_AI_PROVIDER_NAME=custom
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=
CUSTOM_AI_API_URL=

# AI Timeouts
AI_CONNECT_TIMEOUT_SECS=10
AI_READ_TIMEOUT_SECS=90
AI_WRITE_TIMEOUT_SECS=30

# ─────────────────────────────────────────────
# Exchange Configuration
# ─────────────────────────────────────────────
EXCHANGE=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_PASSWORD=
LIVE_TRADING=false
# Enables exchange testnet/sandbox endpoints when LIVE_TRADING=true.
# Keep LIVE_TRADING=false for local paper trading with no exchange order.
EXCHANGE_SANDBOX_MODE=false
EXCHANGE_POOL_MAX_SIZE=50

# ─────────────────────────────────────────────
# Telegram Notifications
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# Risk Management
# ─────────────────────────────────────────────
ACCOUNT_EQUITY_USDT=10000
MAX_POSITION_PCT=10.0
MAX_DAILY_TRADES=10
MAX_DAILY_LOSS_PCT=5.0
EXIT_MANAGEMENT_MODE=ai
AI_RISK_PROFILE=balanced
CUSTOM_STOP_LOSS_PCT=1.5
AI_EXIT_SYSTEM_PROMPT=

# ─────────────────────────────────────────────
# Take Profit Configuration
# ─────────────────────────────────────────────
TP_LEVELS=1
TP1_PCT=2.0
TP2_PCT=4.0
TP3_PCT=6.0
TP4_PCT=10.0
TP1_QTY=25.0
TP2_QTY=25.0
TP3_QTY=25.0
TP4_QTY=25.0

# ─────────────────────────────────────────────
# Trailing Stop Configuration
# ─────────────────────────────────────────────
TRAILING_STOP_MODE=none
TRAILING_STOP_PCT=1.0
TRAILING_ACTIVATION_PCT=1.0
TRAILING_STEP_PCT=0.5

# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
PUBLIC_BASE_URL=
HOST=0.0.0.0
PORT=8000
# Set true only when the app is behind a trusted reverse proxy/CDN.
TRUST_PROXY_HEADERS=false

# ─────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────
# SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./data/server.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/quantpilot_ai

# Database Pool Settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ─────────────────────────────────────────────
# Redis Cache (optional)
# ─────────────────────────────────────────────
REDIS_URL=redis://:${REDIS_PASSWORD:-changeme-in-production}@localhost:6379/0
REDIS_ENABLED=false
REDIS_TTL=300
REDIS_PASSWORD=changeme-in-production

# Database (PostgreSQL when using Docker)
POSTGRES_PASSWORD=changeme-in-production
SIGNAL_SERVER_IMAGE=ghcr.io/ikun52012/quantpilot-ai:latest
SIGNAL_UPDATER_IMAGE=ghcr.io/ikun52012/quantpilot-ai-updater:latest
AUTO_UPDATE_ENABLED=true

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_SECS=300
REGISTER_MAX_ATTEMPTS=5
REGISTER_WINDOW_SECS=600
WEBHOOK_MAX_ATTEMPTS=30
WEBHOOK_WINDOW_SECS=60

# ─────────────────────────────────────────────
# Position Monitor
# ─────────────────────────────────────────────
POSITION_MONITOR_INTERVAL_SECS=60

# ─────────────────────────────────────────────
# Pre-Filter
# ─────────────────────────────────────────────
PREFILTER_DISABLED_CHECKS=

# ─────────────────────────────────────────────
# Enhanced Filters (v3)
# ─────────────────────────────────────────────
ENHANCED_FILTERS_ENABLED=true

# Open Interest Change
OI_CHANGE_THRESHOLD_PCT=5.0
OI_CHANGE_LOOKBACK_HOURS=4

# Whale Activity
WHALE_THRESHOLD_USD=1000000
WHALE_ALERT_API_KEY=

# Correlated Assets
CORRELATED_ASSETS_ENABLED=true
CORRELATED_ASSETS_LOOKBACK_BARS=24

# Etherscan API (for whale blockchain data)
ETHERSCAN_API_KEY=

# Glassnode API (optional)
GLASSNODE_API_KEY=

# CryptoQuant API (optional)
CRYPTOQUANT_API_KEY=

# ─────────────────────────────────────────────
# SMC Analyzer (Smart Money Concepts)
# ─────────────────────────────────────────────
SMC_FVG_LOOKBACK=5
SMC_FVG_MIN_GAP_PCT=0.5
SMC_OB_THRESHOLD=0.5
SMC_SWING_LOOKBACK=3
SMC_MIN_IMPULSE_PCT=0.5

# ─────────────────────────────────────────────
# Voting Configuration
# ─────────────────────────────────────────────
VOTING_ENABLED=false
VOTING_STRATEGY=weighted
VOTING_MIN_CONFIDENCE=0.6
VOTING_TIMEOUT_SECS=120
AI_VOTING_MODELS=[]
AI_VOTING_WEIGHTS={}

# ─────────────────────────────────────────────
# Strategy Monitor
# ─────────────────────────────────────────────
STRATEGY_MONITOR_ENABLED=false
STRATEGY_MONITOR_INTERVAL_SECS=60
STRATEGY_MONITOR_MAX_POSITIONS=10

# ─────────────────────────────────────────────
# Backtest Defaults
# ─────────────────────────────────────────────
BACKTEST_DEFAULT_CAPITAL=10000
BACKTEST_DEFAULT_LEVERAGE=1.0
BACKTEST_DEFAULT_FEE_PCT=0.04
BACKTEST_DEFAULT_SLIPPAGE_PCT=0.01

# ─────────────────────────────────────────────
# WebSocket Configuration
# ─────────────────────────────────────────────
WS_POSITION_UPDATE_INTERVAL_SECS=5
WS_PRICE_UPDATE_INTERVAL_SECS=3
WS_HEARTBEAT_INTERVAL_SECS=30

# ─────────────────────────────────────────────
# PWA / Mobile
# ─────────────────────────────────────────────
PWA_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=false

# ─────────────────────────────────────────────
# i18n / Language
# ─────────────────────────────────────────────
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,zh,ja,ko,es,ru,fr,de,pt,vi

# ─────────────────────────────────────────────
# Two-Factor Authentication (2FA / TOTP)
# ─────────────────────────────────────────────
# 2FA is optional and can be enabled per-user from the dashboard.
# No global toggle needed — each user controls their own 2FA.

# ─────────────────────────────────────────────
# Security Warning
# ─────────────────────────────────────────────
# ⚠️ PRODUCTION WARNING: Change DEFAULT_ADMIN_PASSWORD and JWT_SECRET
# to strong, unique values before exposing to the internet!
# Failure to do so puts your trading accounts at extreme risk.
